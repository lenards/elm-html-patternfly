{
    "type": "package",
    "name": "lenards/elm-html-patternfly",
    "summary": "An elm/html implementation of PatternFly 6 design system components",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "PF6.Css",
        "PF6.Alert",
        "PF6.Avatar",
        "PF6.Badge",
        "PF6.Banner",
        "PF6.Breadcrumb",
        "PF6.Button",
        "PF6.Card",
        "PF6.Checkbox",
        "PF6.Divider",
        "PF6.EmptyState",
        "PF6.HelperText",
        "PF6.Hint",
        "PF6.Icon",
        "PF6.Label",
        "PF6.List",
        "PF6.Spinner",
        "PF6.ActionList",
        "PF6.CodeBlock",
        "PF6.DescriptionList",
        "PF6.ExpandableSection",
        "PF6.Progress",
        "PF6.Radio",
        "PF6.Bullseye",
        "PF6.Flex",
        "PF6.Gallery",
        "PF6.Grid",
        "PF6.Level",
        "PF6.Split",
        "PF6.Stack",
        "PF6.Title",
        "PF6.NumberInput",
        "PF6.SearchInput",
        "PF6.Select",
        "PF6.Switch",
        "PF6.TextArea",
        "PF6.TextInput",
        "PF6.Masthead",
        "PF6.Navigation",
        "PF6.Page"
